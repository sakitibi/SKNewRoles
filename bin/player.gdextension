[configuration]
entry_symbol = "player_library_init"
compatibility_minimum = "4.2"

[libraries]
macos.debug = "res://bin/libgodot_player_extension.dylib"
macos.release = "res://bin/libgodot_player_extension.dylib"
windows.debug.x86_64 = "res://bin/godot_player_extension.dll"
windows.release.x86_64 = "res://bin/godot_player_extension.dll"
linux.debug.x86_64 = "res://bin/libgodot_player_extension.so"
linux.release.x86_64 = "res://bin/libgodot_player_extension.so"